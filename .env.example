# YouTube Niche Analyzer - Configuration

# YouTube API Configuration
# Get your API key from: https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable "YouTube Data API v3"
# 3. Create an "API key" credential
# 4. Paste it below (without the 'YOUTUBE_API_KEY=' part)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Database Configuration
# Path to SQLite database file
DATABASE_PATH=data/youtube_analyzer.db

# Output Configuration
# Directory where reports will be saved
OUTPUT_DIR=output

# Logging Configuration
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Feature Flags
# Extract video transcripts (requires more API quota)
EXTRACT_TRANSCRIPTS=true

# Analyze thumbnails visually
ANALYZE_THUMBNAILS=true

# Generate visualizations
CREATE_VISUALIZATIONS=true

# Analysis Parameters
# Number of videos to analyze by default
DEFAULT_VIDEO_COUNT=50

# Minimum/maximum videos that can be analyzed
MIN_VIDEO_COUNT=10
MAX_VIDEO_COUNT=500

# Cache expiration (hours)
CACHE_DURATION_HOURS=24

# API Rate Limiting
# Delay between API requests (seconds)
RATE_LIMIT_DELAY=0.1

# Request timeout (seconds)
REQUEST_TIMEOUT=10

# Maximum retries for failed requests
MAX_RETRIES=3

# Trending Analysis
# How many days back to look for trending topics
TRENDING_LOOKBACK_DAYS=30
